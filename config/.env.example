# OpenClaw secrets — copy this to ~/.openclaw/.env and fill in real values
# chmod 600 ~/.openclaw/.env

# LLM provider (Groq) — get a key at https://console.groq.com
GROQ_API_KEY=<your-groq-api-key>

# OpenClaw gateway auth token — generate with: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# Telegram bot token (optional) — get from @BotFather on Telegram
OPENCLAW_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
